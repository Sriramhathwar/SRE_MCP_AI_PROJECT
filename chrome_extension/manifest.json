{
  "manifest_version": 3,
  "name": "SRE AI Assistant",
  "version": "1.0",

  "permissions": ["sidePanel"],

  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Open AI Assistant"
  },

  "side_panel": {
    "default_path": "popup.html"
  }
}